# UIH Excel Tools - .gitignore

# ============================================================================
# 1) 不入版本控制的内容
# ============================================================================

# Node 依赖
node_modules/

# 运行时缓存（避免推送用户数据）
.cache/
UIH_AI_Base_PI/

# PowerShell 临时脚本
*.ps1.tmp
gen-icons.ps1

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# 2) 不忽略的（关键：保留 dist/ 给开发者参考）
# ============================================================================
# 重要: 我们的 dist/ 是 vite 构建产物,提交到仓库后,
# 别人 clone 后可以立刻知道最终产物的样子,不用重新构建
# 但他们仍需要 npm install + vite build 来调试前端代码
#
# 因此**不**把 dist/ 加入 .gitignore
# !dist/

# SEA 中间产物（中间文件,不提交）
# build/ 是构建中间产物目录
build/

# 临时 PowerShell 文件
gen-icons.ps1

# 调试输出
exe-output*.txt
exe-error*.txt
verify-result.txt
3003-context.txt
3003-full-context.txt
3003-raw.txt

# 私钥（开发用证书,不入库）
cert.pem
key.pem

# 任务窗格打包临时
.blob-tmp/

# LFS lock file
*.lfs
