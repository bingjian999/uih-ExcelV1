@echo off
setlocal
chcp 65001 >nul
title UIH Excel Tools Diagnostic
echo ==========================================
echo   UIH Excel Tools Diagnostic (Offline)
echo ==========================================
echo.

REM Decode base64 (UTF-16LE) to a temp PS1, then run it.
set "TEMP_PS=%TEMP%\UIH-Diagnose-inline.ps1"
set ""
powershell -NoProfile -Command " = [System.Convert]::FromBase64String();  = [System.Text.Encoding]::Unicode.GetString(); [System.IO.File]::WriteAllText(, , [System.Text.Encoding]::UTF8)"
if errorlevel 1 (
    echo [ERROR] Failed to write inline script.
    pause
    exit /b 1
)

powershell -NoProfile -ExecutionPolicy Bypass -File "%TEMP_PS%"
set "EXITCODE=%ERRORLEVEL%"

echo.
echo ==========================================
echo   Diagnostic finished (exit code: %EXITCODE%)
echo ==========================================
echo.
echo Please screenshot all output above and send back.
echo.
del "%TEMP_PS%" >nul 2>&1
pause
endlocal & exit /b %EXITCODE%