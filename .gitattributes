# 自动检测文本默认以 LF 提交，批处理/PowerShell 保留 CRLF
* text=auto eol=lf

*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# 文档强制 LF
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf

# 二进制
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.xlsx      binary
*.pdf       binary

# EXE 与 SEA blob 用 Git LFS 跟踪（如启用）
*.exe       filter=lfs diff=lfs merge=lfs -text
*.blob      filter=lfs diff=lfs merge=lfs -text
*.pem       text eol=lf
*.key       text eol=lf
